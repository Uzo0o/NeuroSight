<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NeuroSight.Views.MainWindow"
        Icon="/Assets/avalonia-logo.ico"
        Title="NeuroSight"
        Width="1280" Height="720"
        WindowDecorations="None"
        Background="Transparent" 
        TransparencyLevelHint="Transparent">
    
    <!-- Outer Window Border -->
    <Border CornerRadius="20" Background="#121212" ClipToBounds="True" BorderBrush="#2A2A2A" BorderThickness="1">
        
        <Grid ColumnDefinitions="80, *">
            
            <!-- ============================== -->
            <!-- LEFT SIDEBAR                   -->
            <!-- ============================== -->
            <Grid Grid.Column="0" Background="#18181A" RowDefinitions="Auto, *, Auto" PointerPressed="TopBarPointerPressed">
                
                <!-- App Logo -->
                <Border Grid.Row="0" Width="45" Height="45" CornerRadius="12" Background="#25252A" Margin="0,25,0,20">
                    <TextBlock Text="NS" Foreground="#00E676" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <!-- Navigation Menu -->
                <StackPanel Grid.Row="1" Spacing="15" Margin="0,20,0,0">
                    
                    <!-- 1. Setup Button -->
                    <Button x:Name="NavSetupBtn" Width="50" Height="50" Background="#2A2A30" CornerRadius="12" Click="NavSetup_Click" ToolTip.Tip="Camera &amp; Crop Setup">
                        <Path Fill="#00E676" Stretch="Uniform" Width="22" Height="22" 
                              Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.47,5.34 14.86,5.08L14.47,2.42C14.43,2.18 14.22,2 13.97,2H9.97C9.72,2 9.51,2.18 9.47,2.42L9.08,5.08C8.47,5.34 7.9,5.66 7.38,6.05L4.89,5.05C4.67,4.96 4.4,5.05 4.29,5.27L2.29,8.73C2.17,8.95 2.22,9.22 2.41,9.37L4.52,11C4.48,11.34 4.45,11.67 4.45,12C4.45,12.33 4.48,12.65 4.52,12.97L2.41,14.63C2.22,14.78 2.17,15.05 2.29,15.27L4.29,18.73C4.4,18.95 4.67,19.04 4.89,18.95L7.38,17.95C7.9,18.34 8.47,18.66 9.08,18.92L9.47,21.58C9.51,21.82 9.72,22 9.97,22H13.97C14.22,22 14.43,21.82 14.47,21.58L14.86,18.92C15.47,18.66 16.04,18.34 16.56,17.95L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"/>
                    </Button>
                    
                    <!-- 2. Run Engine Button (Play Icon) -->
                    <Button x:Name="NavRunBtn" Width="50" Height="50" Background="Transparent" CornerRadius="12" Click="NavRun_Click" ToolTip.Tip="Live AI Engine">
                        <Path Fill="#888888" Stretch="Uniform" Width="20" Height="20" Data="M8,5.14V19.14L19,12.14L8,5.14Z"/>
                    </Button>

                    <!-- 3. Output/vMix Button (Broadcast Icon) -->
                    <Button x:Name="NavOutputBtn" Width="50" Height="50" Background="Transparent" CornerRadius="12" ToolTip.Tip="vMix / Output Setup">
                        <Path Fill="#888888" Stretch="Uniform" Width="22" Height="22" Data="M12,10A2,2 0 0,1 14,12C14,12.5 13.82,12.94 13.53,13.29L16.7,17.4C17.5,16.27 18,14.87 18,13.33A6,6 0 0,0 12,7.33C10.5,7.33 9.15,7.84 8.1,8.68L10.82,11.39C11.12,10.5 11.66,10 12,10M8.53,13.29C8.23,12.94 8,12.5 8,12C8,11.5 8.18,11.06 8.47,10.71L5.3,6.6C4.5,7.73 4,9.13 4,10.67A8,8 0 0,0 12,18.67C13.5,18.67 14.85,18.16 15.9,17.32L13.18,14.61C12.88,15.5 12.34,16 12,16A2,2 0 0,1 10,14C10,13.5 10.18,13.06 10.47,12.71L8.53,13.29Z"/>
                    </Button>
                </StackPanel>

                <!-- Exit Button -->
                <Button Grid.Row="2" Width="40" Height="40" Background="Transparent" Margin="0,0,0,20" Click="BtnExit_Click">
                    <Path Fill="#C62828" Stretch="Uniform" Width="18" Height="18" Data="M17,17H22V19H17V22L12,18L17,14V17M13,2V5H5V19H13V22H3V2H13Z"/>
                </Button>
            </Grid>
            
            <!-- ============================== -->
            <!-- RIGHT MAIN CONTENT AREA        -->
            <!-- ============================== -->
            <Grid Grid.Column="1" RowDefinitions="50, *">
                
                <!-- Draggable Top Title Bar -->
                <Grid Grid.Row="0" Background="Transparent" PointerPressed="TopBarPointerPressed">
                    <TextBlock x:Name="ScreenTitleText" Text="Configuration Setup" VerticalAlignment="Center" Margin="30,0,0,0" FontWeight="SemiBold" Foreground="White" FontSize="18"/>
                </Grid>
                
                <!-- THIS IS THE MAGIC BOX: We will inject UserControls into here from C# -->
                <TransitioningContentControl Grid.Row="1" x:Name="MainContentArea" Margin="20,0,20,20">
                    <TransitioningContentControl.PageTransition>
                        <CrossFade Duration="0:0:0.25"/>
                    </TransitioningContentControl.PageTransition>
                </TransitioningContentControl>

            </Grid>
        </Grid>
    </Border>
</Window>