<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NeuroSight.Views.SetupView">
             
    <Border Background="#1A1A1E" CornerRadius="15" Padding="25">
        <Grid RowDefinitions="Auto, *, Auto">
            
            <!-- Camera Controls -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="15">
                <ComboBox x:Name="CameraDropdown" Width="300" PlaceholderText="Select Camera Input" Background="#25252A" CornerRadius="8"/>
                <Button x:Name="BtnStart" Content="Start Feed" Background="#00E676" Foreground="#121212" FontWeight="Bold" CornerRadius="8" Padding="15,8"/>
                <Button x:Name="BtnStop" Content="Stop" Background="#C62828" Foreground="White" CornerRadius="8" Padding="15,8"/>
            </StackPanel>
            
            <!-- Video Preview (We will add the drawing canvas over this later) -->
            <Border Grid.Row="1" Margin="0,20,0,20" Background="#0A0A0C" CornerRadius="10" ClipToBounds="True">
                <Grid>
                    <!-- 1. The Live Video Feed -->
                    <Image x:Name="VideoFeedDisplay" Stretch="Uniform"/>
                    
                    <!-- 2. The Transparent Overlay that catches mouse clicks -->
                    <!-- Background="Transparent" is REQUIRED, otherwise it won't detect clicks! -->
                    <Canvas x:Name="DrawCanvas" 
                            Background="Transparent"
                            PointerPressed="Canvas_PointerPressed"
                            PointerMoved="Canvas_PointerMoved"
                            PointerReleased="Canvas_PointerReleased" />
                </Grid>
            </Border>
            
            <!-- Instructions/Status -->
            <TextBlock x:Name="StatusText" Grid.Row="2" Text="Select a camera to begin cropping." Foreground="#888888"/>
        </Grid>
    </Border>
</UserControl>